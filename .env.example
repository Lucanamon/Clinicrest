# Copy to `.env` next to docker-compose.yml (never commit `.env`).
# Production: use strong secrets and a secrets manager where possible.

POSTGRES_DB=miniflowdb
POSTGRES_USER=miniflow
POSTGRES_PASSWORD=miniflowpass

JWT_ISSUER=clinicrest-api
JWT_AUDIENCE=clinicrest-web
# At least 32 random bytes as base64 or a long random string
JWT_SECRET=replace-with-cryptographically-random-secret

ASPNETCORE_ENVIRONMENT=Production

# SMTP (credentials are read from env, not appsettings.json)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Clinicrest Notifications
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password

# Host ports (map Docker web to host; open the host firewall for remote clients, e.g. 26.243.113.13)
API_PORT=8080
WEB_PORT=80

# Docker Hub (for registry-based compose / CI deploy)
# DOCKERHUB_USERNAME=youruser
# IMAGE_TAG=latest
