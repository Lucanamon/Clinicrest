# Copy to `.env` next to docker-compose.yml (never commit `.env`).
# Production: use strong secrets and a secrets manager where possible.

POSTGRES_DB=miniflowdb
POSTGRES_USER=miniflow
POSTGRES_PASSWORD=miniflowpass

JWT_ISSUER=clinicrest-api
JWT_AUDIENCE=clinicrest-web
# At least 32 random bytes as base64 or a long random string
JWT_SECRET=replace-with-cryptographically-random-secret

ASPNETCORE_ENVIRONMENT=Production

# SMTP — credentials and optional overrides (Host/Port/From* may also live in appsettings.json only).
# .NET maps double-underscores to colons. These names must match what the API binds: Email → Smtp → Username, etc.
# With Docker Compose, these are passed to the API container. With `dotnet run`, set the same in your shell/IDE
# (a .env file in the repo is NOT loaded by the API process unless your tooling does so).
Email__Smtp__Username=replace-with-smtp-username
Email__Smtp__Password=replace-with-smtp-app-password
# Optional overrides (omit to use appsettings.json Email:Smtp for host/from):
# Email__Smtp__Host=smtp.gmail.com
# Email__Smtp__Port=587
# Email__Smtp__EnableSsl=true
# Email__Smtp__FromEmail=noreply@example.com
# Email__Smtp__FromName=Clinicrest Notifications

# Host ports (map Docker web to host; open the host firewall for remote clients, e.g. 26.243.113.13)
API_PORT=8080
WEB_PORT=80

# Docker Hub (for registry-based compose / CI deploy)
# DOCKERHUB_USERNAME=youruser
# IMAGE_TAG=latest
